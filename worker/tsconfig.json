{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["src/**/*", "../src/engine/**/*", "../src/net/protocol.ts", "../src/net/room.ts", "../src/net/transport.ts", "../src/net/codes.ts", "../src/ui/public-notices.ts", "../src/ui/events.ts"]
}
