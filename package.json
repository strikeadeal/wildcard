{
  "name": "wildcard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json && tsc -p worker/tsconfig.json --noEmit",
    "icons": "node scripts/make-icons.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "dev:worker": "wrangler dev --config worker/wrangler.jsonc --port 8787",
    "deploy:worker": "wrangler deploy --config worker/wrangler.jsonc"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260711.1",
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "sharp": "^0.35.3",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.110.0"
  }
}
